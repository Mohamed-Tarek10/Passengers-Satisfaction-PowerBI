    <worksheet name='Sheet 5'>
      <table>
        <view>
          <datasources>
            <datasource caption='Airport Passengers Dataset' name='federated.0808sl11tetb0l1dbwncg0eu85q6' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0808sl11tetb0l1dbwncg0eu85q6'>
            <column aggregation='CountD' caption='Distance Segment' datatype='string' name='[Calculation_1677590873519550480]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
              <calculation class='tableau' formula='IF [Flight Distance] &lt; 500 THEN &apos;Short Haul&apos;&#13;&#10;ELSEIF [Flight Distance] &gt;= 500 AND [Flight Distance] &lt; 2500 THEN &apos;Medium Haul&apos;&#13;&#10;ELSE &apos;Long Haul&apos;&#13;&#10;END' />
            </column>
            <column caption='Customer Type (Cleaned)' datatype='string' name='[Calculation_425590174600683520]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Customer Type] = &quot;disloyal Customer&quot; THEN &#13;&#10;    &quot;Disloyal Customer&quot; &#13;&#10;ELSE &#13;&#10;    [Customer Type] &#13;&#10;END' />
            </column>
            <column caption='Total Passengers' datatype='integer' name='[Calculation_425590174601482243]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([id])' />
            </column>
            <column datatype='string' name='[Customer Type]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Flight Distance]' role='measure' type='quantitative' />
            <column caption='Id' datatype='integer' name='[id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1677590873519550480]' derivation='None' name='[none:Calculation_1677590873519550480:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_425590174600683520]' derivation='None' name='[none:Calculation_425590174600683520:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_425590174601482243]' derivation='User' name='[usr:Calculation_425590174601482243:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
