      <column aggregation='CountD' caption='Distance Segment' datatype='string' name='[Calculation_1677590873519550480]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='IF [Flight Distance] &lt; 500 THEN &apos;Short Haul&apos;&#13;&#10;ELSEIF [Flight Distance] &gt;= 500 AND [Flight Distance] &lt; 2500 THEN &apos;Medium Haul&apos;&#13;&#10;ELSE &apos;Long Haul&apos;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Dummy Latitude' datatype='integer' name='[Calculation_1677590873524486167]' role='dimension' semantic-role='[Country].[Name]' type='ordinal'>
        <calculation class='tableau' formula='CASE [Calculation_1677590873519550480]&#13;&#10;    WHEN &apos;Short Haul&apos; THEN 10&#13;&#10;    WHEN &apos;Medium Haul&apos; THEN 30&#13;&#10;    WHEN &apos;Long Haul&apos; THEN 50&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Dummy Longitude' datatype='integer' name='[Calculation_1677590873524625432]' role='dimension' semantic-role='[Country].[Name]' type='ordinal'>
        <calculation class='tableau' formula='CASE [Calculation_1677590873519550480]&#13;&#10;    WHEN &apos;Short Haul&apos; THEN 10&#13;&#10;    WHEN &apos;Medium Haul&apos; THEN 40&#13;&#10;    WHEN &apos;Long Haul&apos; THEN 70&#13;&#10;END' />
      </column>
      <column caption='Net Satisfaction Score' datatype='real' datatype-customized='true' default-format='p0.00%' name='[Calculation_1677590873528897561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [satisfaction] = &quot;satisfied&quot; THEN 1 ELSE 0 END) - SUM(IF [satisfaction] = &quot;neutral or dissatisfied&quot; THEN 1 ELSE 0 END)) / COUNT([id])' />
