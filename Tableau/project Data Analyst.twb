    <worksheet name='Net Satisfaction Score'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Courier New'>Net Satisfaction Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Airport Passengers Dataset' name='federated.0808sl11tetb0l1dbwncg0eu85q6' />
          </datasources>
          <datasource-dependencies datasource='federated.0808sl11tetb0l1dbwncg0eu85q6'>
            <column caption='Net Satisfaction Score' datatype='real' datatype-customized='true' default-format='p0.00%' name='[Calculation_1677590873528897561]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM(IF [satisfaction] = &quot;satisfied&quot; THEN 1 ELSE 0 END) - SUM(IF [satisfaction] = &quot;neutral or dissatisfied&quot; THEN 1 ELSE 0 END)) / COUNT([id])' />
            </column>
            <column caption='Customer Type (Cleaned)' datatype='string' name='[Calculation_425590174600683520]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Customer Type] = &quot;disloyal Customer&quot; THEN &#13;&#10;    &quot;Disloyal Customer&quot; &#13;&#10;ELSE &#13;&#10;    [Customer Type] &#13;&#10;END' />
            </column>
            <column datatype='string' name='[Class]' role='dimension' type='nominal' />
            <column datatype='string' name='[Customer Type]' role='dimension' type='nominal' />
            <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
            <column datatype='string' name='[Type of Travel]' role='dimension' type='nominal' />
            <column caption='Id' datatype='integer' name='[id]' role='dimension' type='ordinal' />
            <column-instance column='[Type of Travel]' derivation='None' name='[none:Type of Travel:nk]' pivot='key' type='nominal' />
            <column caption='Satisfaction' datatype='string' name='[satisfaction]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1677590873528897561]' derivation='User' name='[usr:Calculation_1677590873528897561:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
